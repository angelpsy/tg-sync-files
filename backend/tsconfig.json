{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",

    "baseUrl": "./src",
    "paths": {
      "@/types": ["../../types"]
    },

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "types": ["node", "jest"]
  },
  "include": ["src/**/*"],
  "exclude": ["dist"]
}
