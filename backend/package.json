{
  "name": "@tg-sync-files/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/backend/src/index.js",
  "scripts": {
    "dev": "dotenv -e ../.env vite",
    "dev:ws": "dotenv -e ../.env tsx watch src/index.ts",
    "build:tsc": "tsc",
    "build": "vite build",
    "start": "dotenv -e ../.env node dist-vite/index.js",
    "start:legacy": "dotenv -e ../.env node dist/backend/src/index.js",
    "start:ws": "dotenv -e ../.env node dist-vite/index.js",
    "typecheck": "tsc --noEmit",
    "prisma:sqlite:sync": "dotenv -e ../.env prisma db push",
    "prisma:sqlite:generate": "dotenv -e ../.env prisma generate",
    "prisma:sqlite:reset": "dotenv -e ../.env prisma db push --force-reset",
    "prisma:db:push": "pnpm prisma:sqlite:sync",
    "prisma:generate": "pnpm prisma:sqlite:generate",
    "prisma:migrate:dev": "echo \"Deprecated for SQLite mode: use 'pnpm prisma:sqlite:sync'\" && pnpm prisma:sqlite:sync",
    "prisma:migrate:prod": "echo \"Deprecated for SQLite mode: use 'pnpm prisma:sqlite:sync'\" && pnpm prisma:sqlite:sync",
    "test": "jest"
  },
  "dependencies": {
    "@prisma/client": "^6.13.0",
    "big-integer": "^1.6.52",
    "chokidar": "^4.0.3",
    "dotenv": "^17.2.1",
    "dotenv-expand": "^12.0.2",
    "dotenv-schema": "^0.1.1",
    "express": "^5.1.0",
    "file-type": "^21.0.0",
    "input": "1.0.1",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.1",
    "telegram": "^2.26.22",
    "tsyringe": "^4.8.0",
    "winston": "^3.17.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.3",
    "dotenv-cli": "^10.0.0",
    "jest": "^29.7.0",
    "prisma": "^6.13.0",
    "ts-jest": "^29.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.1",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
