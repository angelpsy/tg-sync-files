# Environment variables example for tg-sync-files project

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Database URL for Prisma (SQLite)
DATABASE_URL="file:./dev.db"

# =============================================================================
# TELEGRAM API CONFIGURATION
# =============================================================================
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# Comma-separated list of Telegram channel IDs (not JSON array)
TELEGRAM_CHANNEL_IDS="-1001234567890,-1009876543210"

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Directory to watch for file changes
WATCH_DIR=/path/to/watch/directory

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================
# Backend WebSocket server port
BACKEND_WS_PORT=4000

# Frontend development server port
FRONTEND_PORT=3000

# WebSocket endpoint for frontend (Next.js NEXT_PUBLIC_ variable)
NEXT_PUBLIC_WS_ENDPOINT=ws://localhost:4000

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
# Node environment
NODE_ENV=development

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# General log level (error, warn, info, http, debug)
LOG_LEVEL=info

# Individual service log levels (optional)
# If not specified, LOG_LEVEL will be used as default
LOG_LEVEL_FS=debug         # File System Service
LOG_LEVEL_TELEGRAM=info    # Telegram Service  
LOG_LEVEL_SYNC=debug       # Sync Service
LOG_LEVEL_STORAGE=info     # Storage Service
LOG_LEVEL_SOCKET=debug     # Socket Service
LOG_LEVEL_SCHEDULER=warn   # Scheduler Service
LOG_LEVEL_API=info         # API Service

# CORS Origins (comma-separated for backend)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Note: DATABASE_URL points to local SQLite DB file.
# For Docker this is mounted to /app/backend/prisma/db.sqlite in backend container.
