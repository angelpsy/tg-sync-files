{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowImportingTsExtensions": true,
    "noEmit": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/shared/*": ["../shared/*"],
      "@/types": ["../types"],
      "@/types/*": ["../types/*"]
    },

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "types": ["node", "jest"]
  },
  "include": ["src/**/*", "../types/**/*"],
  "exclude": ["dist"]
}
