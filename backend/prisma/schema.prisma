// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Telegram channel configuration
model Channel {
  id        String   @id
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  topics            Topic[]
  fileSyncEvents    FileSyncEvent[]

  @@map("channels")
}

// Topics within channels
model Topic {
  id        String   @id
  name      String
  channelId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  channel           Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  folderTopicLinks  FolderTopicLink[]
  uploadSessions    UploadSession[]
  fileRecords       FileRecord[]

  @@map("topics")
}

// Folder-Topic links
model FolderTopicLink {
  id         String   @id @default(cuid())
  folderPath String
  topicId    String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([folderPath, topicId])
  @@map("folder_topic_links")
}

// Upload sessions tracking
model UploadSession {
  id            String       @id @default(cuid())
  folderPath    String
  topicId       String
  status        UploadStatus @default(PENDING)
  totalFiles    Int
  uploadedFiles Int          @default(0)
  currentFile   String?
  progress      Float        @default(0)
  startedAt     DateTime
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  completedAt   DateTime?
  error         String?
  // Extended metrics (optional)
  realUploadedFiles Int?      @default(0)
  skippedFilesCount Int?      @default(0)
  conflictsSkipped   Int?      @default(0)
  conflictsRenamed   Int?      @default(0)
  conflictsLogged    Int?      @default(0)

  // Relations
  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@map("upload_sessions")
}

// Telegram session data
model TelegramSession {
  id            String   @id @default(cuid())
  stringSession String   @db.Text
  phoneNumber   String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("telegram_sessions")
}

// File sync events tracking
model FileSyncEvent {
  id        String     @id @default(cuid())
  fileName  String
  filePath  String
  channelId String
  status    SyncStatus @default(PENDING)
  error     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@map("file_sync_events")
}

// File records (uploaded files metadata per topic)
model FileRecord {
  id         String   @id @default(cuid())
  topicId    String
  folderPath String
  fileName   String
  size       Int
  mtimeMs    BigInt
  hash       String?  @db.Text
  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([topicId, fileName])
  @@map("file_records")
}

// Enum for sync status
enum SyncStatus {
  PENDING
  SYNCING
  COMPLETED
  ERROR
}

// Enum for upload status
enum UploadStatus {
  PENDING
  UPLOADING
  PAUSED
  COMPLETED
  PARTIAL
  FAILED
}
