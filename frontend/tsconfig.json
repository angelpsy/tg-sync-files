{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    // Frontend-специфичные настройки
    "target": "es5",
    "lib": ["dom", "dom.iterable", "es6"],
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],

    // Frontend-специфичные алиасы
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/components/*": ["./components/*"],
      "@/lib/*": ["./lib/*"],
      "@/app/*": ["./app/*"],
      "@/types": ["../types"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../types/**/*",
    "next.config.js",
    "postcss.config.js"
  ]
}
