{
  "name": "tg-sync-files",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "types"
  ],
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=24.5.0",
    "pnpm": ">=10.14.0"
  },
  "scripts": {
    "dev": "concurrently -n \"BACKEND,FRONTEND\" -c \"magenta,blue\" \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:backend": "pnpm --filter backend dev:ws",
    "dev:frontend": "pnpm --filter frontend dev",
    "start": "bash scripts/prod.sh",
    "prod:backend": "pnpm --filter backend build && pnpm --filter backend start",
    "build": "pnpm --filter backend build && pnpm --filter frontend build",
    "build:types": "pnpm --filter types build",
    "db:sync": "pnpm --filter backend prisma:sqlite:sync",
    "db:reset": "pnpm --filter backend prisma:sqlite:reset",
    "build:docker": "docker compose build",
    "generate:api": "echo 'API generation not configured yet'",
    "generate:sdk": "echo 'SDK generation not configured yet'",
    "typecheck": "pnpm --filter backend typecheck && pnpm --filter frontend typecheck",
    "typecheck:watch": "tsc --noEmit --watch",
    "lint": "eslint . --ext .js,.ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .js,.ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:dev": "docker compose -f docker-compose.yml up --build",
    "docker:logs": "docker compose logs -f",
    "docker:clean": "docker compose down -v --remove-orphans",
    "prepare": "husky || true",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "install:all": "pnpm install --frozen-lockfile"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "concurrently": "^10.0.3",
    "dotenv-expand": "^13.0.0",
    "eslint": "^10.6.0",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "glob": "13.0.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  }
}
