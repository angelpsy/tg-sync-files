# Environment variables example for tg-sync-files project

# PostgreSQL credentials
POSTGRES_DB=tg_sync_files
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Telegram API credentials from my.telegram.org
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# Comma-separated list of Telegram channel IDs (not JSON array)
TELEGRAM_CHANNEL_IDS="-1001234567890,-1009876543210"

# Directory to watch for file changes
WATCH_DIR=/path/to/watch/directory

# Ports configuration
BACKEND_WS_PORT=4000
FRONTEND_PORT=3000

# WebSocket endpoint for frontend connection
WS_ENDPOINT=ws://localhost:4000

# Next.js Authentication secret key
NEXTAUTH_SECRET=your-secret-key-here

# Development/Production environment
NODE_ENV=development

# Note: DATABASE_URL is auto-generated from PostgreSQL credentials above
# For local development: postgresql://postgres:postgres@localhost:5432/tg_sync_files
# For Docker: postgresql://postgres:postgres@postgres:5432/tg_sync_files
